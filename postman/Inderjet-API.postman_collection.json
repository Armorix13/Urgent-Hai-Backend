          }
        },
        {
          "name": "Delete Drive file",
          "request": {
            "auth": { "type": "noauth" },
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v1/google-drive/file/{{drive_file_id}}",
            "description": "Uses drive_file_id (set after upload)."
          }
        }
