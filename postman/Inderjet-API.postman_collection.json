    {
      "name": "Enrollment",
      "item": [
        {
          "name": "Enroll in Course",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const j = pm.response.json();",
                  "    if (j.enrollment && j.enrollment._id) {",
                  "        pm.collectionVariables.set('enrollment_id', j.enrollment._id);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"courseId\": \"{{course_id}}\",\n  \"transactionId\": \"txn_123\",\n  \"paymentMethod\": \"razorpay\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/enrollment",
            "description": "Requires Bearer. Free course: omit transactionId/paymentMethod. Paid: include them. Uses {{course_id}}. Saves enrollment _id to {{enrollment_id}} on 201."
          }
        },
        {
          "name": "Get My Enrollments",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const j = pm.response.json();",
                  "    const first = j.enrollments && j.enrollments[0];",
                  "    if (first && first._id) pm.collectionVariables.set('enrollment_id', first._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": "{{baseUrl}}/api/v1/enrollment",
            "description": "Requires Bearer. Each item: course + myRating { rating, review, updatedAt } or null. Saves first enrollment _id to {{enrollment_id}}."
