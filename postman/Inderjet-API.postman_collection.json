    {
      "name": "Google Drive",
      "item": [
        {
          "name": "Upload to Drive (form-data)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    const id = json.data?.file?.fileId || json.data?.files?.[0]?.fileId;",
                  "    if (id) pm.collectionVariables.set('drive_file_id', id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "files",
                  "type": "file",
                  "src": [],
                  "description": "Required: choose file. For more files, add another form field with the same key \"files\"."
                },
                {
                  "key": "folder",
                  "type": "text",
                  "value": "",
                  "description": "Optional: e.g. uploads/test — created under GOOGLE_DRIVE_FOLDER_ID"
                }
              ]
            },
            "url": "{{baseUrl}}/api/v1/google-drive/upload",
            "description": "Body must be form-data (not raw JSON). Keys: **files** = File (required). **folder** = Text (optional). Single-file alternative: use key **file** instead of **files**. Optional folder also as query: ?folder=my/subfolder"
          }
        },
        {
          "name": "Get Drive file metadata",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/google-drive/file/{{drive_file_id}}",
