{
  "info": {
    "name": "Inderjet API",
    "description": "Inderjet / Naadaman backend — full API collection.\n\n**Collection variables:** `baseUrl`, `access_token` (set by Login), `course_id`, `enrollment_id`, `drive_file_id`.\n\n**Course list/detail:** Send `Authorization: Bearer {{access_token}}` on GET `/course` (optional) to receive `isEnrolled` + `myRating` per course.\n\n**Enrollment & rating:** All `/enrollment/*` and `/rating/*` routes require Bearer token.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "access_token",
      "value": ""
    },
    {
      "key": "drive_file_id",
      "value": ""
    },
    {
      "key": "course_id",
      "value": "69c386622cc88cc8526b6584"
    },
    {
      "key": "enrollment_id",
      "value": ""
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "User",
      "item": [
        {
          "name": "Register",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@yopmail.com\",\n  \"password\": \"password123\",\n  \"userName\": \"TestUser\",\n  \"deviceType\": 2,\n  \"deviceToken\": \"device_token_here\",\n  \"age\": 25,\n  \"gender\": 1,\n  \"language\": \"English\",\n  \"phoneNumber\": \"9876543210\",\n  \"countryCode\": \"+91\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/user/user-register",
            "description": "Register new user. Returns success + email for OTP verification."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    if (json.user && json.user.access_token) {",
                  "        pm.collectionVariables.set('access_token', json.user.access_token);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@yopmail.com\",\n  \"password\": \"password123\",\n  \"deviceType\": 2,\n  \"deviceToken\": \"device_token_here\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/user/user-login",
            "description": "Login. Saves access_token to collection for use in other requests."
          }
        },
        {
          "name": "Social Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    if (json.user && json.user.access_token) {",
                  "        pm.collectionVariables.set('access_token', json.user.access_token);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@gmail.com\",\n  \"provider\": \"google\",\n  \"providerId\": \"google_oauth_id_123\",\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"profileImage\": \"https://example.com/photo.jpg\",\n  \"phoneNumber\": \"9876543210\",\n  \"countryCode\": \"+91\",\n  \"deviceType\": 2,\n  \"deviceToken\": \"device_token_here\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/user/social-login",
            "description": "Social login (Google/Apple). Saves access_token automatically."
          }
        },
        {
          "name": "Get User Details",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": "{{baseUrl}}/api/v1/user/user-detail",
            "description": "Get current user profile + subscription + currentPlan + isPremium"
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Inderjit\",\n  \"email\": \"inder@yopmail.com\",\n  \"age\": 22,\n  \"gender\": \"male\",\n  \"phoneNumber\": \"9876543210\",\n  \"countryCode\": \"+91\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/user/user-update",
            "description": "Update profile. Supports userName, fullName, email, age, gender, profileImage, etc."
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"oldPassword\": \"password123\",\n  \"newPassword\": \"newPassword456\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/user/change-password",
            "description": "Change password. Requires oldPassword and newPassword."
          }
        },
        {
          "name": "Forget Password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@yopmail.com\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/user/forget-password",
            "description": "Send OTP to email for password reset"
          }
        },
        {
          "name": "Verify OTP",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": 1,\n  \"otp\": 123456,\n  \"email\": \"user@yopmail.com\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/user/verify-otp",
            "description": "Verify OTP. type=1 for email verification, returns tokens"
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@yopmail.com\",\n  \"password\": \"newPassword123\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/user/reset-password",
            "description": "Reset password after OTP verification"
          }
        },
        {
          "name": "Delete Account",
          "request": {
            "method": "DELETE",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": "{{baseUrl}}/api/v1/user/delete-account",
            "description": "Permanently delete user account"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": "{{baseUrl}}/api/v1/user/user-logout",
            "description": "Invalidates session (clears jti, device fields). Discard access_token on client."
          }
        }
      ]
    },
