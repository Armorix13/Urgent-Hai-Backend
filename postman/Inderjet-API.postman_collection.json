    {
      "name": "Plan",
      "item": [
        {
          "name": "Get All Plans",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/plan?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "plan"],
              "query": [
                {"key": "page", "value": "1"},
                {"key": "limit", "value": "10"},
                {"key": "isActive", "value": "true", "disabled": true}
              ]
            },
            "description": "Get all subscription plans (public, no auth)"
          }
        },
        {
          "name": "Get Plan by ID",
          "request": {
            "auth": { "type": "noauth" },
